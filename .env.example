# Copy to .env and fill in your local paths.
# ASR_CORPUS_ROOT points to the root of your local audio collection.
# Each corpus sub-directory must match the corpus id in corpora/.
# Example: /data/asr_benchmark/corpora  →  /data/asr_benchmark/corpora/example/audio/
ASR_CORPUS_ROOT=/path/to/your/local/corpora
