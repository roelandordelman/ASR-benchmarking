fn100068 1 N100018 299.372 302.146 <o,compq,native_elderly,F> een bekertje warme chocolademelk moet je wel lusten
fn100068 1 N100018 303.365 306.180 <o,compq,native_elderly,F> door jouw gezeur zijn we nu al meer dan een uur te laat
fn100068 1 N100018 306.180 307.211 <o,compq,native_elderly,F> voor die afspraak
fn100068 1 N100018 308.610 310.505 <o,compq,native_elderly,F> met een flinke garage erbij
fn100068 1 N100018 310.505 313.443 <o,compq,native_elderly,F> moet je genoeg opbergruimte hebben
fn100068 1 N100018 315.905 317.379 <o,compq,native_elderly,F> een foutje van de stuurman
fn100068 1 N100018 317.379 319.134 <o,compq,native_elderly,F> heeft het schip doen kapseizen
fn100068 1 N100018 320.241 322.061 <o,compq,native_elderly,F> gerokt door een stukje kaas
fn100068 1 N100018 322.061 323.947 <o,compq,native_elderly,F> liep het muisje keurig in de val
fn100068 1 N100018 325.161 327.324 <o,compq,native_elderly,F> het ziet er naar uit da dat het deze week bij ons
fn100068 1 N100018 327.324 328.541 <o,compq,native_elderly,F> opnieuw gaat regenen
fn100068 1 N100018 329.716 331.307 <o,compq,native_elderly,F> na die grote lekkage
fn100068 1 N100018 331.307 333.357 <o,compq,native_elderly,F> was het dure behang aan vervanging toe
fn100068 1 N100018 334.618 336.818 <o,compq,native_elderly,F> geduldig hou ik de deur voor je open
fn100068 1 N100018 339.606 341.243 <o,compq,native_elderly,F> het ongeluk veroorzaakte
fn100068 1 N100018 341.243 342.921 <o,compq,native_elderly,F> enorme ravage
fn100068 1 N100018 342.921 345.495 <o,compq,native_elderly,F> honderden auto's waren in elkaar gedrukt
fn100068 1 N100018 346.584 348.499 <o,compq,native_elderly,F> de socialistische premier
fn100068 1 N100018 348.499 350.804 <o,compq,native_elderly,F> moest zijn zwaarste wapen uit de kast halen
fn100068 1 N100018 352.020 353.656 <o,compq,native_elderly,F> zij blijven het flatje huren
fn100068 1 N100018 353.656 355.595 <o,compq,native_elderly,F> tot ze een leuk huis hebben gevonden
fn100068 1 N100018 356.782 358.086 <o,compq,native_elderly,F> de beurs is van plan
fn100068 1 N100018 358.486 361.415 <o,compq,native_elderly,F> om het bedrijf in juni negentien vierennegentig
fn100068 1 N100018 361.415 363.253 <o,compq,native_elderly,F> uit de de notering te halen
fn100068 1 N100018 364.415 366.283 <o,compq,native_elderly,F> de toekomst van Jeroen is door zijn ouders
fn100068 1 N100018 366.283 368.095 <o,compq,native_elderly,F> al helemaal uitgestippeld
fn100072 1 N100017 12.624 12.911 <o,compq,native_elderly,F>
fn100072 1 N100017 13.375 15.515 <o,compq,native_elderly,F> veel Nederlanders vieren elk
fn100072 1 N100017 15.515 17.604 <o,compq,native_elderly,F> jaar hun verjaardag en hun trouwdag
fn100072 1 N100017 18.162 20.120 <o,compq,native_elderly,F> een verjaardag vieren ze meestal
fn100072 1 N100017 20.120 22.818 <o,compq,native_elderly,F> thuis met het gezin met een paar vrienden
fn100072 1 N100017 22.818 23.842 <o,compq,native_elderly,F> of met familie
fn100072 1 N100017 24.696 27.340 <o,compq,native_elderly,F> op de jaarlijkse trouwdag krijgt de vrouw vaak
fn100072 1 N100017 27.340 29.309 <o,compq,native_elderly,F> een bos bloemen of ze gaat
fn100072 1 N100017 29.309 31.779 <o,compq,native_elderly,F> met haar man in een restaurant eten
fn100072 1 N100017 37.981 40.614 <o,compq,native_elderly,F> de prijs van een heleboel dingen in Nederland
fn100072 1 N100017 40.614 41.328 <o,compq,native_elderly,F> is vast
fn100072 1 N100017 41.589 43.647 <o,compq,native_elderly,F> dat betekent dat je niet kunt
fn100072 1 N100017 43.647 46.095 <o,compq,native_elderly,F> praten met de verkoper over een lagere prijs
fn100072 1 N100017 46.095 47.821 <o,compq,native_elderly,F> voor sommige
fn100072 1 N100017 47.821 50.484 <o,compq,native_elderly,F> dingen is dat heel duidelijk
fn100072 1 N100017 50.484 52.954 <o,compq,native_elderly,F> voor groente of fruit kleren
fn100072 1 N100017 52.954 55.894 <o,compq,native_elderly,F> en andere niet zo grote en dure artikelen
fn100072 1 N100017 55.894 58.865 <o,compq,native_elderly,F> betaal je gewoon de prijs die erop staat
fn100072 1 N100017 58.865 61.858 <o,compq,native_elderly,F> of diet verkoper er voor vraagt
fn100072 1 N100017 66.084 69.055 <o,compq,native_elderly,F> dit is niet zo bij spullen die niet nieuw zijn
fn100072 1 N100017 69.055 70.763 <o,compq,native_elderly,F> tweedehands spullen
fn100072 1 N100017 71.471 73.703 <o,compq,native_elderly,F> daarbij is het juist heel normaal
fn100072 1 N100017 73.703 75.922 <o,compq,native_elderly,F> als je probeert minder te betalen
fn100072 1 N100017 76.730 79.724 <o,compq,native_elderly,F> ook bij tweedehands auto's is de vraagprijs nooit
fn100072 1 N100017 79.724 81.981 <o,compq,native_elderly,F> de prijs die je er echt voor betaalt
fn100072 1 N100017 81.981 84.132 <o,compq,native_elderly,F> je betaalt altijd minder
fn100072 1 N100017 84.847 86.469 <o,compq,native_elderly,F> of je vraagt er nog grat
fn100072 1 N100017 87.409 89.951 <o,compq,native_elderly,F> post kun je versturen via de brievenbus
fn100072 1 N100017 90.415 92.578 <o,compq,native_elderly,F> als je een brief voor 's avonds zes uur
fn100072 1 N100017 92.578 94.570 <o,compq,native_elderly,F> op de bus doet komt de brief
fn100072 1 N100017 94.570 96.870 <o,compq,native_elderly,F> binnen Nederland de volgende dag aan
fn100072 1 N100017 97.580 99.931 <o,compq,native_elderly,F> post die niet in de brievenbus past
fn100072 1 N100017 99.931 101.624 <o,compq,native_elderly,F> verstuur je in een pakket
fn100072 1 N100017 102.554 104.539 <o,compq,native_elderly,F> pakketten zijn er in verschillende
fn100072 1 N100017 104.539 105.792 <o,compq,native_elderly,F> soorten en maten
fn100072 1 N100017 106.179 108.614 <o,compq,native_elderly,F> je kunt ze voor allerlei dingen gebruiken
fn100072 1 N100017 111.930 114.500 <o,compq,native_elderly,F> een gemeente is een stad of een dorp
fn100072 1 N100017 114.500 116.494 <o,compq,native_elderly,F> of een paar kleine dorpen samen
fn100072 1 N100017 117.172 119.237 <o,compq,native_elderly,F> ambtenaren van de gemeente
fn100072 1 N100017 119.237 122.234 <o,compq,native_elderly,F> controleren of alle kinderen naar school gaan
fn100072 1 N100017 122.904 125.625 <o,compq,native_elderly,F> de gemeente houdt de stad schoon en zorgt
fn100072 1 N100017 125.625 127.913 <o,compq,native_elderly,F> voor goede straten en fietspaden
fn100072 1 N100017 128.789 131.670 <o,compq,native_elderly,F> ook zorgt de gemeente voor de bomen en de parken
fn100072 1 N100017 132.586 133.790 <o,compq,native_elderly,F> het is belangrijk
fn100072 1 N100017 133.790 135.397 <o,compq,native_elderly,F> voor veel dingen
fn100072 1 N100017 135.397 137.355 <o,compq,native_elderly,F> moet je in Nederland naar een balie
fn100072 1 N100017 137.355 139.825 <o,compq,native_elderly,F> bijvoorbeeld naar het gemeentehuis
fn100072 1 N100017 139.825 142.318 <o,compq,native_elderly,F> de bank of naar het postkantoor
fn100072 1 N100017 142.876 144.821 <o,compq,native_elderly,F> meestal zijn er al meer mensen
fn100072 1 N100017 144.821 146.607 <o,compq,native_elderly,F> en moet je wachten totda
fn100072 1 N100017 146.607 147.942 <o,compq,native_elderly,F> tot je aan de beurt bent
fn100072 1 N100017 148.515 150.996 <o,compq,native_elderly,F> je kunt niet even iets gk anders gaan doen
fn100072 1 N100017 150.996 153.061 <o,compq,native_elderly,F> want dan ben je je plaats kwijt
fn100072 1 N100017 156.982 159.896 <o,compq,native_elderly,F> soms kun je nummertjes trekken uit een apparaat
fn100072 1 N100017 159.896 161.660 <o,compq,native_elderly,F> en kun je bij de balie zien
fn100072 1 N100017 161.660 163.447 <o,compq,native_elderly,F> welk nummer aan de beurt is
fn100072 1 N100017 164.336 166.044 <o,compq,native_elderly,F> als het nog erg lang duurt
fn100072 1 N100017 166.044 167.865 <o,compq,native_elderly,F> voor jouw nummer aan de beurt is
fn100072 1 N100017 167.865 170.028 <o,compq,native_elderly,F> kun je wel even een boodschap gaan doen
fn100072 1 N100017 170.706 171.762 <o,compq,native_elderly,F> maar niet te lang
fn100072 1 N100017 171.762 173.874 <o,compq,native_elderly,F> want als jouw nummer geweest is
fn100072 1 N100017 173.874 175.846 <o,compq,native_elderly,F> moet je weer een nieuw nummer trekken
fn100072 1 N100017 178.937 181.293 <o,compq,native_elderly,F> het Nederlands heeft een apart woord
fn100072 1 N100017 181.293 182.136 <o,compq,native_elderly,F> voor gezin
fn100072 1 N100017 182.944 185.790 <o,compq,native_elderly,F> een gezin bestaat uit ouders en kinderen
fn100072 1 N100017 186.653 188.895 <o,compq,native_elderly,F> ze wonen bijna altijd apart
fn100072 1 N100017 188.895 190.386 <o,compq,native_elderly,F> van de rest van de familie
fn100072 1 N100017 191.377 193.197 <o,compq,native_elderly,F> de familie is veel groter
fn100072 1 N100017 193.197 195.038 <o,compq,native_elderly,F> opa's en oma's
fn100072 1 N100017 195.038 196.507 <o,compq,native_elderly,F> tantes en ooms
fn100072 1 N100017 196.507 198.010 <o,compq,native_elderly,F> neven en nichten
fn100072 1 N100017 198.546 201.266 <o,compq,native_elderly,F> in Nederland zijn vooral de relaties
fn100072 1 N100017 201.266 203.258 <o,compq,native_elderly,F> binnen het gezin belangrijk
fn100072 1 N100017 205.588 208.081 <o,compq,native_elderly,F> Nederlanders praten veel over het weer
fn100072 1 N100017 208.081 210.198 <o,compq,native_elderly,F> omdat het weer vaak verandert
fn100072 1 N100017 210.198 212.179 <o,compq,native_elderly,F> en het helemaal niet zeker is
fn100072 1 N100017 212.179 214.815 <o,compq,native_elderly,F> wat voor weer het is in de lente zomer
fn100072 1 N100017 214.815 215.999 <o,compq,native_elderly,F> herfst of winter
fn100072 1 N100017 216.779 218.612 <o,compq,native_elderly,F> er zijn veel uitdrukkingen
fn100072 1 N100017 218.612 221.332 <o,compq,native_elderly,F> die met het vaak onzekere weer te maken hebben
fn100072 1 N100017 222.184 224.533 <o,compq,native_elderly,F> bijvoorbeeld het kan vriezen
fn100072 1 N100017 224.533 225.868 <o,compq,native_elderly,F> en het kan dooien
fn100072 1 N100017 225.868 228.547 <o,compq,native_elderly,F> dat betekent dat je nog niet weet
fn100072 1 N100017 228.547 229.868 <o,compq,native_elderly,F> hoe iets zal gaan
fn100072 1 N100017 233.508 235.781 <o,compq,native_elderly,F> gedichten gaan vaak over de liefde
fn100072 1 N100017 236.122 239.013 <o,compq,native_elderly,F> dichters vertellen graag over hun geliefde
fn100072 1 N100017 239.704 241.958 <o,compq,native_elderly,F> een dichter kan in weinig woorden
fn100072 1 N100017 241.958 243.449 <o,compq,native_elderly,F> zijn gevoel uitdrukken
fn100072 1 N100017 243.449 245.737 <o,compq,native_elderly,F> of een idee of iets grappigs
fn100072 1 N100017 246.730 248.677 <o,compq,native_elderly,F> liedjes lijken op gedichten
fn100072 1 N100017 248.677 251.659 <o,compq,native_elderly,F> de vorm is het zelfde en ze gaan
fn100072 1 N100017 251.659 253.481 <o,compq,native_elderly,F> ook vaak over de liefde
fn100072 1 N100017 254.454 256.321 <o,compq,native_elderly,F> in liedjes gaat het natuurlijk
fn100072 1 N100017 256.321 258.233 <o,compq,native_elderly,F> om meer dan alleen de woorden
fn100072 1 N100017 258.233 261.063 <o,compq,native_elderly,F> de muziek en de stem van de zanger
fn100072 1 N100017 261.063 263.624 <o,compq,native_elderly,F> zijn net zo belangrijk als de tekst
fn100072 1 N100017 266.248 268.969 <o,compq,native_elderly,F> onrijpe pruimen zijn hard en zuur
fn100072 1 N100017 269.857 272.111 <o,compq,native_elderly,F> de bus komt er zo aan
fn100072 1 N100017 272.845 275.224 <o,compq,native_elderly,F> moet je nog veel slingers ophangen
fn100072 1 N100017 276.101 278.101 <o,compq,native_elderly,F> ik vind appelsap niet lekker
fn100072 1 N100017 278.998 281.958 <o,compq,native_elderly,F> er zit al een flinke deuk in je nieuwe auto
fn100072 1 N100017 285.015 286.438 <o,compq,native_elderly,F> op een druk station
fn100072 1 N100017 286.438 288.464 <o,compq,native_elderly,F> moet je op je bagage letten
