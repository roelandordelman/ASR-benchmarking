fn000639 1 N000240 141.681 142.916 <o,compq,native_teens,F> je kunt niet
fn000639 1 N000240 142.916 144.944 <o,compq,native_teens,F> je kunt niet even iets anders gaan doen
fn000639 1 N000240 144.944 146.496 <o,compq,native_teens,F> want dan ben je je plaats kwijt
fn000639 1 N000240 149.812 152.074 <o,compq,native_teens,F> soms kun je nummertjes trekken
fn000639 1 N000240 152.074 154.601 <o,compq,native_teens,F> uit een apparaat en kun je bij de balie
fn000639 1 N000240 155.098 156.321 <o,compq,native_teens,F> er aan de beurt is
fn000639 1 N000240 156.321 158.161 <o,compq,native_teens,F> als als het nog erg lang duurt
fn000639 1 N000240 158.161 159.637 <o,compq,native_teens,F> voor jouw nummer aan de beurt is
fn000639 1 N000240 160.265 162.147 <o,compq,native_teens,F> dan kun je wel even een boodschap gaan doen
fn000639 1 N000240 162.899 164.675 <o,compq,native_teens,F> maar niet te lang
fn000639 1 N000240 164.675 166.388 <o,compq,native_teens,F> want als je nummer is geweest
fn000639 1 N000240 166.388 167.839 <o,compq,native_teens,F> moet je weer een nieuw nummer trekken
fn000639 1 N000240 170.595 171.995 <o,compq,native_teens,F> het Nederlands
fn000639 1 N000240 171.995 173.982 <o,compq,native_teens,F> heeft een apart woord voor gezin
fn000639 1 N000240 173.982 176.158 <o,compq,native_teens,F> het gezin bestaat uit ouders en kinderen
fn000639 1 N000240 176.492 178.338 <o,compq,native_teens,F> ze wonen bijna altijd apart
fn000639 1 N000240 178.338 179.762 <o,compq,native_teens,F> van de rest van de familie
fn000639 1 N000240 179.762 181.420 <o,compq,native_teens,F> familie is veel groter
fn000639 1 N000240 181.420 183.248 <o,compq,native_teens,F> opa's en oma's
fn000639 1 N000240 183.248 185.929 <o,compq,native_teens,F> tantes ooms neven en nichten
fn000639 1 N000240 185.929 188.293 <o,compq,native_teens,F> in Nederland zijn vooral de relaties
fn000639 1 N000240 188.293 189.951 <o,compq,native_teens,F> binnen het gezin belangrijk
fn000639 1 N000240 192.702 194.043 <o,compq,native_teens,F> Nederlanders praten veel
fn000639 1 N000240 194.043 196.372 <o,compq,native_teens,F> over het weer omdat het weer vaak verandert
fn000639 1 N000240 196.835 199.611 <o,compq,native_teens,F> en zeker is wat voor weer
fn000639 1 N000240 200.151 203.080 <o,compq,native_teens,F> het is in de lente zomer herfst of winter
fn000639 1 N000240 203.515 206.302 <o,compq,native_teens,F> er zijn veel uitdrukkingen die met het vaak
fn000639 1 N000240 206.302 207.961 <o,compq,native_teens,F> onzekere weer te maken hebben
fn000639 1 N000240 207.961 208.977 <o,compq,native_teens,F> bijvoorbeeld
fn000639 1 N000240 208.977 211.209 <o,compq,native_teens,F> het kan vriezen en dat kan dooien
fn000639 1 N000240 211.209 212.211 <o,compq,native_teens,F> en het kan dooien
fn000639 1 N000240 212.669 214.516 <o,compq,native_teens,F> zo dat betekent
fn000639 1 N000240 214.516 216.927 <o,compq,native_teens,F> dat je nog niet weet hoe iets zal gaan
fn000639 1 N000240 219.942 222.153 <o,compq,native_teens,F> gedichten gaan vaak over de liefde
fn000639 1 N000240 222.153 223.929 <o,compq,native_teens,F> dichters vertellen graag
fn000639 1 N000240 224.354 225.804 <o,compq,native_teens,F> graag over hun gelief
fn000639 1 N000240 226.780 228.076 <o,compq,native_teens,F> een dichter kan
fn000639 1 N000240 228.076 230.374 <o,compq,native_teens,F> in weinig woorden zijn gevoel uitdrukken
fn000639 1 N000240 230.907 233.495 <o,compq,native_teens,F> of een of een idee of iets grappigs
fn000639 1 N000240 233.958 235.734 <o,compq,native_teens,F> liedjes lijken op gedichten
fn000639 1 N000240 235.734 237.749 <o,compq,native_teens,F> de vorm is hetzelfde en ze gaan vaak
fn000639 1 N000240 237.749 238.792 <o,compq,native_teens,F> ook over liefde
fn000639 1 N000240 239.792 240.816 <o,compq,native_teens,F> in de liedjes
fn000639 1 N000240 241.313 242.486 <o,compq,native_teens,F> in de liedjes gaat het
fn000639 1 N000240 242.486 244.394 <o,compq,native_teens,F> om meer dan alleen de woorden
fn000639 1 N000240 244.394 246.583 <o,compq,native_teens,F> de muziek en de stem van de zanger
fn000639 1 N000240 246.583 248.359 <o,compq,native_teens,F> zijn net zo belangrijk als de tekst
fn000639 1 N000240 251.173 253.102 <o,compq,native_teens,F> onrijpe pruimen zijn hard en zuur
fn000639 1 N000240 253.561 254.866 <o,compq,native_teens,F> de bus komt er zo aan
fn000639 1 N000240 255.419 257.485 <o,compq,native_teens,F> moet je nog s veel slingers ophangen
fn000639 1 N000240 257.485 259.881 <o,compq,native_teens,F> ik vind de appel ik vind appelsap niet lekker
fn000639 1 N000240 260.281 262.350 <o,compq,native_teens,F> er zit een flinke deuk in je nieuwe auto
fn000639 1 N000240 265.836 267.788 <o,compq,native_teens,F> op een druk stati station
fn000639 1 N000240 268.235 270.082 <o,compq,native_teens,F> moet je op je bagage letten
fn000639 1 N000240 270.481 273.086 <o,compq,native_teens,F> ik draag een oranje trui met lange mouwen
fn000639 1 N000240 273.086 274.762 <o,compq,native_teens,F> het leven wordt steeds duurder
fn000639 1 N000240 274.762 277.241 <o,compq,native_teens,F> de man van mijn zus fietst elke dag
fn000639 1 N000240 277.679 280.153 <o,compq,native_teens,F> haar lieve kinderen krijgen leuke cadeautjes
fn000639 1 N000240 283.768 285.942 <o,compq,native_teens,F> ik wou om half drie hier zijn
fn000639 1 N000240 285.942 288.173 <o,compq,native_teens,F> om alles in de etalage te zetten
fn000639 1 N000240 288.173 290.025 <o,compq,native_teens,F> de voetballer belooft zijn
fn000639 1 N000240 290.025 291.759 <o,compq,native_teens,F> contrauele
fn000639 1 N000240 291.759 293.787 <o,compq,native_teens,F> verplichtingen na te komen
fn000639 1 N000240 294.287 296.686 <o,compq,native_teens,F> de juffrouw rust een middagje uit
fn000639 1 N000240 296.686 297.709 <o,compq,native_teens,F> en doet een dutje
fn000639 1 N000240 297.709 299.361 <o,compq,native_teens,F> de chauffeur tracht
fn000639 1 N000240 299.361 300.972 <o,compq,native_teens,F> met wilde bewegingen
fn000639 1 N000240 300.972 302.771 <o,compq,native_teens,F> de kuilen in de weg om te s
fn000639 1 N000240 302.771 304.312 <o,compq,native_teens,F> om te omzeilen
fn000639 1 N000240 304.888 305.841 <o,compq,native_teens,F> de huis
fn000639 1 N000240 306.605 309.376 <o,compq,native_teens,F> vitrage is heel ouderwets en past niet
fn000639 1 N000240 309.376 311.079 <o,compq,native_teens,F> bij een modern interieur
fn000639 1 N000240 311.488 313.301 <o,compq,native_teens,F> de Nederlandse gulden is al lang
fn000639 1 N000240 313.301 315.417 <o,compq,native_teens,F> even hard als de Duitse mark
fn000639 1 N000240 316.023 318.176 <o,compq,native_teens,F> een bekertje warme chocolademelk
fn000639 1 N000240 318.176 319.315 <o,compq,native_teens,F> moet je wel lusten
fn000639 1 N000240 319.315 321.409 <o,compq,native_teens,F> door jouw gezeur zijn we nu al meer dan een
fn000639 1 N000240 321.409 322.938 <o,compq,native_teens,F> uur te laat voor die afspraak
fn000639 1 N000240 322.938 325.459 <o,compq,native_teens,F> met flink met een flinke garage erbij
fn000639 1 N000240 325.459 326.471 <o,compq,native_teens,F> moet je nog
fn000639 1 N000240 326.471 329.305 <o,compq,native_teens,F> moet n genoeg opruim-bergruimte hebben
fn000639 1 N000240 335.214 337.060 <o,compq,native_teens,F> een foutje van de stuurman
fn000639 1 N000240 337.060 339.071 <o,compq,native_teens,F> heeft het schip doen kapseizen
fn000639 1 N000240 339.675 340.598 <o,compq,native_teens,F> het geklokt
fn000639 1 N000240 341.087 343.515 <o,compq,native_teens,F> het geklokt door een stukje kaas
fn000639 1 N000240 343.515 345.873 <o,compq,native_teens,F> liep het muisje keurig in de val
fn000639 1 N000240 346.838 347.311 <o,compq,native_teens,F> het
fn000639 1 N000240 348.058 349.456 <o,compq,native_teens,F> het ziet ernaar uit
fn000639 1 N000240 349.971 352.781 <o,compq,native_teens,F> dat het deze week bij ons opnieuw gaat regenen
fn000639 1 N000240 353.275 356.004 <o,compq,native_teens,F> na die grote lekkage was het dure behang
fn000639 1 N000240 356.004 357.102 <o,compq,native_teens,F> aan vervanging toe
fn000639 1 N000240 357.620 359.889 <o,compq,native_teens,F> geduldig hou ik de deur voor je open
fn000639 1 N000240 363.112 365.599 <o,compq,native_teens,F> het het ongeluk veroorzaakte enorm
fn000639 1 N000240 365.599 366.992 <o,compq,native_teens,F> een enorme ravage
fn000639 1 N000240 367.409 369.215 <o,compq,native_teens,F> honderden auto's gedrukt
fn000639 1 N000240 369.956 371.485 <o,compq,native_teens,F> socialistische priem
fn000639 1 N000240 371.485 373.442 <o,compq,native_teens,F> de socialistische premier
fn000639 1 N000240 373.442 376.123 <o,compq,native_teens,F> moest zijn zwaarste wapen uit de kast halen
fn000639 1 N000240 376.570 378.275 <o,compq,native_teens,F> zij blijven het flatje huren
fn000639 1 N000240 378.275 380.580 <o,compq,native_teens,F> tot ze een leuk huis hebben gevonden
fn000639 1 N000240 381.291 383.831 <o,compq,native_teens,F> de beurs is van plan om het bedrijf
fn000639 1 N000240 383.831 386.218 <o,compq,native_teens,F> in juni negentien vier
fn000639 1 N000240 386.218 388.182 <o,compq,native_teens,F> en negen en negentig
fn000639 1 N000240 388.182 389.916 <o,compq,native_teens,F> uit de notering te halen
fn000639 1 N000240 390.821 392.950 <o,compq,native_teens,F> de toekomst van Jeroen is door zijn ouders
fn000639 1 N000240 392.950 394.514 <o,compq,native_teens,F> al helemaal uitgestippeld
fn000641 1 N000241 12.178 13.413 <o,compq,native_teens,M> veel Nederlanders
fn000641 1 N000241 13.413 15.404 <o,compq,native_teens,M> vieren elk jaar hun verjaardag
fn000641 1 N000241 15.404 16.586 <o,compq,native_teens,M> en hun trouwdag
fn000641 1 N000241 17.376 18.284 <o,compq,native_teens,M> een verjaardag
fn000641 1 N000241 18.284 20.485 <o,compq,native_teens,M> vieren ze meestal thuis met het gezin
fn000641 1 N000241 20.485 22.999 <o,compq,native_teens,M> met een paar vrienden of met familie
fn000641 1 N000241 23.570 25.165 <o,compq,native_teens,M> op de jaarlijkse trouwdag
fn000641 1 N000241 25.165 27.312 <o,compq,native_teens,M> krijgt de vrouw vaak een bos bloemen
fn000641 1 N000241 27.312 30.176 <o,compq,native_teens,M> of gaat ze met haar man in een restaurant eten
fn000641 1 N000241 33.638 35.327 <o,compq,native_teens,M> de prijs van een heleboel dingen
fn000641 1 N000241 35.327 36.735 <o,compq,native_teens,M> in Nederland is vast
fn000641 1 N000241 37.455 38.365 <o,compq,native_teens,M> dat betekent
fn000641 1 N000241 38.365 40.671 <o,compq,native_teens,M> dat je niet kunt praten met een verkoper
fn000641 1 N000241 40.671 42.324 <o,compq,native_teens,M> over een lagere prijs
fn000641 1 N000241 42.887 45.227 <o,compq,native_teens,M> bij sommige dingen is dat heel duidelijk
fn000641 1 N000241 45.891 47.564 <o,compq,native_teens,M> voor groente of fruit
fn000641 1 N000241 47.564 49.774 <o,compq,native_teens,M> kleren en ander niet
fn000641 1 N000241 49.774 52.099 <o,compq,native_teens,M> zo grote en dure artikelen
fn000641 1 N000241 52.099 54.756 <o,compq,native_teens,M> betaal je gewoon de prijs die erop staat
fn000641 1 N000241 54.756 56.817 <o,compq,native_teens,M> of die een verkoper ervoor vraagt
fn000641 1 N000241 60.153 63.130 <o,compq,native_teens,M> dit is niet zo bij spullen die die niet nieuw zijn
fn000641 1 N000241 63.130 64.709 <o,compq,native_teens,M> tweedehands spullen
fn000641 1 N000241 65.249 67.393 <o,compq,native_teens,M> daarbij is het juist heel normaal
fn000641 1 N000241 67.393 69.593 <o,compq,native_teens,M> als je probeer minder te betalen
fn000641 1 N000241 70.152 71.910 <o,compq,native_teens,M> ook bij tweedehands auto's
fn000641 1 N000241 71.910 73.249 <o,compq,native_teens,M> is de vraagprijs
fn000641 1 N000241 73.249 75.873 <o,compq,native_teens,M> nooit de prijs die je er echt voor betaalt
