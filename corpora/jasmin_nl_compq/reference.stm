fn100193 1 N100041 317.972 320.169 <o,compq,native_elderly,F> ik vind appelsap niet lekker.
fn100193 1 N100041 320.169 322.520 <o,compq,native_elderly,F> ik zit al een flinke deuk
fn100193 1 N100041 322.520 323.947 <o,compq,native_elderly,F> in een nieuwe auto.
fn100193 1 N100041 327.714 330.381 <o,compq,native_elderly,F> op een druk station moet je op
fn100193 1 N100041 330.381 332.745 <o,compq,native_elderly,F> de je bagage letten.
fn100193 1 N100041 332.745 335.192 <o,compq,native_elderly,F> ik draag een oranje trui
fn100193 1 N100041 335.192 337.390 <o,compq,native_elderly,F> en een laa met lange mouwen.
fn100193 1 N100041 337.390 339.563 <o,compq,native_elderly,F> het leven wordt steeds duurder.
fn100193 1 N100041 339.563 341.033 <o,compq,native_elderly,F> de man van mijn
fn100193 1 N100041 341.033 343.420 <o,compq,native_elderly,F> zus fiets elkenu dag.
fn100193 1 N100041 343.420 344.885 <o,compq,native_elderly,F> haar lieve kinderen
fn100193 1 N100041 344.885 346.658 <o,compq,native_elderly,F> krijgen leuke cadeautjes.
fn100193 1 N100041 351.284 353.882 <o,compq,native_elderly,F> ik wou al om half drie
fn100193 1 N100041 353.882 355.749 <o,compq,native_elderly,F> hier zijn om alles
fn100193 1 N100041 355.749 357.909 <o,compq,native_elderly,F> in de etalage te zetten.
fn100193 1 N100041 357.909 360.505 <o,compq,native_elderly,F> de voetballer belooft het contra
fn100193 1 N100041 360.505 361.984 <o,compq,native_elderly,F> controla
fn100193 1 N100041 361.984 363.602 <o,compq,native_elderly,F> cuda cuduleu
fn100193 1 N100041 363.602 365.272 <o,compq,native_elderly,F> verplichting na te komen.
fn100193 1 N100041 365.272 366.395 <o,compq,native_elderly,F> de juffrouw rust
fn100193 1 N100041 366.395 368.844 <o,compq,native_elderly,F> een middag uit en doet een dutje.
fn100193 1 N100041 368.844 369.853 <o,compq,native_elderly,F> de chauffeur
fn100193 1 N100041 369.853 371.955 <o,compq,native_elderly,F> tracht met wilde beweging
fn100193 1 N100041 371.955 373.913 <o,compq,native_elderly,F> de kuilen in de weg te
fn100193 1 N100041 374.490 375.999 <o,compq,native_elderly,F> oms-zeilenu.
fn100193 1 N100041 375.999 378.094 <o,compq,native_elderly,F> de huiseigenaar kwam
fn100193 1 N100041 378.094 380.696 <o,compq,native_elderly,F> aan de deur om de huur op te halen.
fn100193 1 N100041 383.149 384.258 <o,compq,native_elderly,F> vitragenu
fn100193 1 N100041 384.853 387.681 <o,compq,native_elderly,F> is heel ouderwets en past niet bij
fn100193 1 N100041 387.681 389.713 <o,compq,native_elderly,F> een moderne interieur.
fn100193 1 N100041 389.713 392.089 <o,compq,native_elderly,F> de Nederlandse ga gulden is la
fn100193 1 N100041 392.089 394.301 <o,compq,native_elderly,F> al lang even hard als
fn100193 1 N100041 394.301 395.635 <o,compq,native_elderly,F> Duitse mark.
fn100193 1 N100041 395.635 397.460 <o,compq,native_elderly,F> een ma bekertje
fn100193 1 N100041 397.460 400.332 <o,compq,native_elderly,F> warme chocolademelk moet je wel lusten.
fn100193 1 N100041 400.874 403.353 <o,compq,native_elderly,F> door jouw gezeur zijn we nu
fn100193 1 N100041 403.353 405.351 <o,compq,native_elderly,F> al meer dan een uur
fn100193 1 N100041 405.351 407.378 <o,compq,native_elderly,F> te laat voor de afspraak.
fn100193 1 N100041 407.378 409.246 <o,compq,native_elderly,F> met een flinke garagieu
fn100193 1 N100041 409.246 410.954 <o,compq,native_elderly,F> erbij moet je genoeg
fn100193 1 N100041 410.954 412.582 <o,compq,native_elderly,F> opbergruimte hebben.
fn100193 1 N100041 416.063 418.299 <o,compq,native_elderly,F> een foutje van de stuurman heeft
fn100193 1 N100041 418.299 419.867 <o,compq,native_elderly,F> het schip doen
fn100193 1 N100041 419.867 420.976 <o,compq,native_elderly,F> kapzeilenu.
fn100193 1 N100041 421.543 422.723 <o,compq,native_elderly,F> gelokt door een
fn100193 1 N100041 422.723 425.192 <o,compq,native_elderly,F> stukje kaas liep het muisje
fn100193 1 N100041 425.192 426.983 <o,compq,native_elderly,F> keurig in de val.
fn100193 1 N100041 426.983 429.504 <o,compq,native_elderly,F> het ziet ernaar uit dat het
fn100193 1 N100041 429.504 432.030 <o,compq,native_elderly,F> deze week bij ons opnieuw ga
fn100193 1 N100041 432.030 433.409 <o,compq,native_elderly,F> gaat regenen.
fn100193 1 N100041 433.409 434.916 <o,compq,native_elderly,F> na de grote
fn100193 1 N100041 434.916 436.554 <o,compq,native_elderly,F> lekt-kageu
fn100193 1 N100041 436.554 438.275 <o,compq,native_elderly,F> was de dure behang
fn100193 1 N100041 438.275 439.856 <o,compq,native_elderly,F> aan vervanging toe.
fn100193 1 N100041 439.856 441.192 <o,compq,native_elderly,F> geduldig hou ik
fn100193 1 N100041 441.192 443.163 <o,compq,native_elderly,F> de deur voor je open.
fn100193 1 N100041 447.456 449.305 <o,compq,native_elderly,F> het ongeluk veroorzaakt
fn100193 1 N100041 449.305 451.033 <o,compq,native_elderly,F> een enorme ravagieu.
fn100193 1 N100041 451.033 453.742 <o,compq,native_elderly,F> honderden auto's waren in elkaar gedruuktu.
fn100193 1 N100041 453.742 455.623 <o,compq,native_elderly,F> de sorareïstetischeu
fn100193 1 N100041 455.623 457.838 <o,compq,native_elderly,F> premie moest zijn zwaarste wapen
fn100193 1 N100041 457.838 459.254 <o,compq,native_elderly,F> uit de kast halen.
fn100193 1 N100041 459.254 462.179 <o,compq,native_elderly,F> zij blijven het flatje huren ia
fn100193 1 N100041 462.179 463.638 <o,compq,native_elderly,F> tot ze een
fn100193 1 N100041 463.638 465.810 <o,compq,native_elderly,F> leuk huisje hebben gevonden.
fn100193 1 N100041 465.810 467.625 <o,compq,native_elderly,F> de beurs is van plan
fn100193 1 N100041 467.625 469.303 <o,compq,native_elderly,F> om het bedrijf in juni
fn100193 1 N100041 469.303 470.946 <o,compq,native_elderly,F> negen-tiens
fn100193 1 N100041 470.946 473.478 <o,compq,native_elderly,F> vier en negen-tigs
fn100193 1 N100041 473.478 475.413 <o,compq,native_elderly,F> uit de notering te halen.
fn100193 1 N100041 475.413 476.917 <o,compq,native_elderly,F> de toekomst van Jeroen
fn100193 1 N100041 476.917 478.517 <o,compq,native_elderly,F> is door zijn ouders al
fn100193 1 N100041 478.517 480.192 <o,compq,native_elderly,F> helemaal uitgestippeld.
fn100202 1 N100046 14.423 15.891 <o,compq,native_elderly,F> veel Nederlanders
fn100202 1 N100046 15.891 18.034 <o,compq,native_elderly,F> vieren elk jaar hun verjaardag
fn100202 1 N100046 18.034 19.349 <o,compq,native_elderly,F> en hun trouwdag.
fn100202 1 N100046 20.026 22.294 <o,compq,native_elderly,F> een verjaardag vieren ze meestal thuis
fn100202 1 N100046 22.294 23.448 <o,compq,native_elderly,F> met het gezin
fn100202 1 N100046 23.448 25.487 <o,compq,native_elderly,F> met een paar vrienden of met familie.
fn100202 1 N100046 26.058 28.676 <o,compq,native_elderly,F> op de jaarlijkse trouwdag krijgt de vrouw vaak
fn100202 1 N100046 28.676 29.791 <o,compq,native_elderly,F> een bos bloemen
fn100202 1 N100046 29.791 32.327 <o,compq,native_elderly,F> of gaat ze met haar man in een restaurant eten.
fn100202 1 N100046 36.628 39.597 <o,compq,native_elderly,F> de prijs van een heleboel dingen in Nederland is vast.
fn100202 1 N100046 39.597 40.916 <o,compq,native_elderly,F> dat betekent
fn100202 1 N100046 40.916 43.158 <o,compq,native_elderly,F> dat je niet kunt praten met de verkoper
fn100202 1 N100046 43.158 44.577 <o,compq,native_elderly,F> over een lagere prijs.
fn100202 1 N100046 45.134 47.468 <o,compq,native_elderly,F> bij sommige dingen is dat heel duidelijk.
fn100202 1 N100046 47.468 49.995 <o,compq,native_elderly,F> voor groenten en fruit kleren
fn100202 1 N100046 49.995 51.839 <o,compq,native_elderly,F> en andere niet zo grote
fn100202 1 N100046 51.839 53.280 <o,compq,native_elderly,F> en dure artikelen
fn100202 1 N100046 53.280 54.890 <o,compq,native_elderly,F> betaal je gewoon de prijs
fn100202 1 N100046 54.890 55.873 <o,compq,native_elderly,F> die erop staat
fn100202 1 N100046 55.873 57.653 <o,compq,native_elderly,F> of die verkoper ervoor vraagt.
fn100202 1 N100046 61.449 63.032 <o,compq,native_elderly,F> dat is niet zo bij spullen
fn100202 1 N100046 63.032 64.302 <o,compq,native_elderly,F> die niet nieuw zijn
fn100202 1 N100046 64.302 65.411 <o,compq,native_elderly,F> tweedehands spullen.
fn100202 1 N100046 65.945 67.893 <o,compq,native_elderly,F> daarbij is 't juist heel normaal
fn100202 1 N100046 67.893 70.054 <o,compq,native_elderly,F> als je probeert minder te betalen.
fn100202 1 N100046 70.658 73.089 <o,compq,native_elderly,F> ook bij tweedehands auto's is de vraagprijs
fn100202 1 N100046 73.089 75.364 <o,compq,native_elderly,F> nooit de prijs die je er echt voor betaalt.
fn100202 1 N100046 75.364 77.172 <o,compq,native_elderly,F> je betaalt altijd minder.
fn100202 1 N100046 77.172 78.200 <o,compq,native_elderly,F> of je vraagt
fn100202 1 N100046 78.200 79.820 <o,compq,native_elderly,F> er nog gratis spullen bij
fn100202 1 N100046 79.820 81.295 <o,compq,native_elderly,F> zoals een cd-speler.
fn100202 1 N100046 83.367 85.642 <o,compq,native_elderly,F> post kun je versturen via de brievenbus.
fn100202 1 N100046 86.185 87.329 <o,compq,native_elderly,F> als je een brief
fn100202 1 N100046 87.329 89.464 <o,compq,native_elderly,F> voor 's avonds zes uur op de bus doet
fn100202 1 N100046 89.464 90.519 <o,compq,native_elderly,F> komt die brief
fn100202 1 N100046 90.519 92.751 <o,compq,native_elderly,F> binnen Nederland de volgende dag aan.
fn100202 1 N100046 93.347 95.841 <o,compq,native_elderly,F> post die niet in de brieven-buss past
fn100202 1 N100046 95.841 97.385 <o,compq,native_elderly,F> verstuur je in een pakket.
fn100202 1 N100046 97.935 100.826 <o,compq,native_elderly,F> pakketten zijn er in verschillende soorten en maten.
fn100202 1 N100046 100.826 103.114 <o,compq,native_elderly,F> je kunt ze voor allerlei dingen gebruiken.
fn100202 1 N100046 106.709 109.268 <o,compq,native_elderly,F> een gemeente is een stad of een dorp
fn100202 1 N100046 109.268 111.382 <o,compq,native_elderly,F> of een paar kleine dorpen samen.
fn100202 1 N100046 111.945 114.391 <o,compq,native_elderly,F> ambtenaren van de gemeente controleren
fn100202 1 N100046 114.391 116.478 <o,compq,native_elderly,F> of alle kinderen naar school gaan.
fn100202 1 N100046 116.478 118.497 <o,compq,native_elderly,F> de gemeente houdt de stad schoon
fn100202 1 N100046 118.497 120.326 <o,compq,native_elderly,F> en zorgt voor goede stradenu
fn100202 1 N100046 120.326 121.744 <o,compq,native_elderly,F> straten en fietspaden.
fn100202 1 N100046 122.260 123.568 <o,compq,native_elderly,F> ook zorgt de gemeente
fn100202 1 N100046 123.568 125.457 <o,compq,native_elderly,F> voor de bomen en de parken.
fn100202 1 N100046 125.457 128.434 <o,compq,native_elderly,F> het is belangrijk dat er voldoende groen is in de stad.
fn100202 1 N100046 132.037 134.848 <o,compq,native_elderly,F> voor veel dingen moet je in Nederland naar een balie.
fn100202 1 N100046 134.848 137.152 <o,compq,native_elderly,F> bijvoorbeeld naar het gemeentehuis
fn100202 1 N100046 137.152 139.460 <o,compq,native_elderly,F> de bank of naar het postkantoor.
fn100202 1 N100046 139.460 141.344 <o,compq,native_elderly,F> meestal zijn er al meer mensen
fn100202 1 N100046 141.344 142.438 <o,compq,native_elderly,F> en moet je wachten
fn100202 1 N100046 142.438 143.852 <o,compq,native_elderly,F> tot je aan de beurt bent.
fn100202 1 N100046 143.852 146.141 <o,compq,native_elderly,F> je kunt niet even iets anders gaan doen
fn100202 1 N100046 146.141 147.702 <o,compq,native_elderly,F> want dan ben je je plaats kwijt.
fn100202 1 N100046 150.863 153.334 <o,compq,native_elderly,F> soms kun je nummertjes trekken uit een apparaat
fn100202 1 N100046 153.334 154.932 <o,compq,native_elderly,F> en kun je bij de balie zien
fn100202 1 N100046 154.932 156.464 <o,compq,native_elderly,F> welk nummer aan de beurt is.
fn100202 1 N100046 156.998 159.685 <o,compq,native_elderly,F> als het nog erg lang duurt voor jouw nummer aan de beurt is
fn100202 1 N100046 159.685 161.562 <o,compq,native_elderly,F> kun je wel even een boodschap gaan doen.
fn100202 1 N100046 161.562 164.263 <o,compq,native_elderly,F> maar niet te lang want als jouw nummer geweest is
fn100202 1 N100046 164.263 165.766 <o,compq,native_elderly,F> moet je weer een nieuw nummer trekken.
fn100202 1 N100046 169.060 171.988 <o,compq,native_elderly,F> het Nederlands heeft een apart woord voor gezin.
fn100202 1 N100046 171.988 174.881 <o,compq,native_elderly,F> een gezin bestaat uit ouders en kinderen.
fn100202 1 N100046 174.881 176.475 <o,compq,native_elderly,F> ze wonen bijna altijd
fn100202 1 N100046 176.475 178.358 <o,compq,native_elderly,F> apart van de rest van de familie.
fn100202 1 N100046 178.358 180.283 <o,compq,native_elderly,F> de familie is veel groter
fn100202 1 N100046 180.283 181.954 <o,compq,native_elderly,F> opa's en oma's
fn100202 1 N100046 181.954 183.365 <o,compq,native_elderly,F> tantes en ooms
fn100202 1 N100046 183.365 184.665 <o,compq,native_elderly,F> neven en nichten.
fn100202 1 N100046 184.665 186.216 <o,compq,native_elderly,F> in Nederland zijn vooral
fn100202 1 N100046 186.216 188.464 <o,compq,native_elderly,F> de relaties binnen 't gezin belangrijk.
fn100202 1 N100046 192.149 194.526 <o,compq,native_elderly,F> Nederlanders praten veel over het weer
fn100202 1 N100046 194.526 196.603 <o,compq,native_elderly,F> omdat het weer vaak verander
fn100202 1 N100046 196.603 198.309 <o,compq,native_elderly,F> en het helemaal niet zeker is
fn100202 1 N100046 198.309 200.079 <o,compq,native_elderly,F> wat voor weer het is in de lente
fn100202 1 N100046 200.079 202.080 <o,compq,native_elderly,F> zomer herfst of winter.
fn100202 1 N100046 202.616 204.956 <o,compq,native_elderly,F> er zijn veel uitdrukkingen die met het
fn100202 1 N100046 204.956 207.114 <o,compq,native_elderly,F> vaak onzekere weer te maken hebben.
fn100202 1 N100046 207.114 208.339 <o,compq,native_elderly,F> bijvoorbeeld
fn100202 1 N100046 208.339 210.744 <o,compq,native_elderly,F> het gea kan vriezen en het kan dooien.
fn100202 1 N100046 210.744 211.777 <o,compq,native_elderly,F> dat betekent
fn100202 1 N100046 211.777 213.958 <o,compq,native_elderly,F> dat je nog niet weet hoe iets zal gaan.
fn100202 1 N100046 217.425 219.635 <o,compq,native_elderly,F> gedichten gaan vaak over de liefde.
fn100202 1 N100046 219.635 222.505 <o,compq,native_elderly,F> dichters vertellen graag over hun geliefde.
fn100202 1 N100046 222.505 224.449 <o,compq,native_elderly,F> een dichter kan in weinig woorden
fn100202 1 N100046 224.449 226.082 <o,compq,native_elderly,F> zijn gevoel uitdrukken
fn100202 1 N100046 226.082 228.014 <o,compq,native_elderly,F> of een idee of iets grappigs.
fn100202 1 N100046 228.717 230.483 <o,compq,native_elderly,F> liedjes lijken op gedichten.
fn100202 1 N100046 230.483 231.978 <o,compq,native_elderly,F> de vorm is hetzelfde
fn100202 1 N100046 231.978 233.903 <o,compq,native_elderly,F> en ze gaan ook vaak over de liefde.
fn100202 1 N100046 234.529 236.507 <o,compq,native_elderly,F> in liedjes gaat 't natuurlijk om meer
fn100202 1 N100046 236.507 237.812 <o,compq,native_elderly,F> dan alleen de woorden.
fn100202 1 N100046 237.812 239.907 <o,compq,native_elderly,F> de muziek en de stem van de zanger
fn100202 1 N100046 239.907 241.725 <o,compq,native_elderly,F> zijn net zo belangrijk als de tekst.
fn100202 1 N100046 246.168 248.861 <o,compq,native_elderly,F> onrijpe pruimen zijn hard en zuur.
fn100202 1 N100046 248.861 250.467 <o,compq,native_elderly,F> de bus komt er zo aan.
